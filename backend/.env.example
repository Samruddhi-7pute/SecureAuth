# ==========================================
# Server
# ==========================================
NODE_ENV=development
PORT=5000

# ==========================================
# MongoDB Atlas
# ==========================================
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/secureauth?retryWrites=true&w=majority

# ==========================================
# JWT
# ==========================================
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=1d
JWT_REMEMBER_EXPIRES_IN=30d
JWT_COOKIE_EXPIRES_IN_DAYS=1
JWT_REMEMBER_COOKIE_EXPIRES_IN_DAYS=30

# ==========================================
# CORS — comma-separated list of allowed frontend origins
# ==========================================
# CLIENT_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,https://your-frontend.netlify.app



CLIENT_ORIGIN=http://localhost:5500,http://127.0.0.1:5500,http://127.0.0.1:3001,https://your-frontend.netlify.app

# ==========================================
# bcrypt
# ==========================================
BCRYPT_SALT_ROUNDS=12

# ==========================================
# Rate limiting
# ==========================================
AUTH_RATE_LIMIT_WINDOW_MINUTES=15
AUTH_RATE_LIMIT_MAX=20
